# Copy to .env for local overrides. All values have safe defaults (see shared/config.ts).

# HTTP
PORT=3000
# Comma-separated origins allowed by CORS in production (no wildcard).
CORS_ALLOWLIST=http://localhost:8080

# FX rate source: "frankfurter" (live, ECB) | "stub" (deterministic)
RATE_PROVIDER=frankfurter
# How long a fetched rate stays cached (ms).
RATE_CACHE_TTL_MS=60000

# Quote time-to-live before it expires (ms).
QUOTE_TTL_MS=60000

# Fee (tiered): flat below threshold; flat + percent above. Amounts in MXN major units.
FEE_FLAT_MXN=20
FEE_THRESHOLD_MXN=5000
FEE_PERCENT=0.01

# Amount bounds (MXN major units).
MIN_AMOUNT_MXN=10
MAX_AMOUNT_MXN=100000

# Secret used to sign quotes (HMAC). MUST be overridden in production.
HMAC_SECRET=dev-insecure-secret-change-me
